# GamesDownloaderV3 - environment variables
# Copy to .env and fill in your values

# ── Host paths (base directory for all persistent data) ───────────────────────
GD_BASE_DIR=/APPS/GamesDownloaderV3

# ── Port (host port -> container 8080) ────────────────────────────────────────
GD_PORT=8080

# ── User / Group ID (optional - run container as specific UID/GID) ────────────
# Leave empty to run as root (default in container)
PUID=
PGID=

# ── Debug mode ────────────────────────────────────────────────────────────────
GD_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# IMPORTANT: change every password below before running on a public network.
# DB_ROOT_PASSWD is set ONCE on the very first start of the MariaDB container,
# baked into its data volume. Changing it later in .env does NOT change it in
# the database.
DB_NAME=gamesdownloader
DB_USER=gd
DB_PASSWD=change-me-strong-random
DB_ROOT_PASSWD=change-me-root-strong-random

# ── Redis password ────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-strong-random

# ── Auth secret key ───────────────────────────────────────────────────────────
# Used to sign JWTs and decrypt secrets stored in app_config (SMTP password,
# OAuth client secrets, scraper API keys). Generate with:
#   openssl rand -hex 32
#
# If you leave this set to "change-me-in-production" or empty, the entrypoint
# will auto-generate a 256-bit key on first start and persist it to
# /data/.secret_key. Keep that file safe: losing it invalidates all sessions
# AND makes encrypted-at-rest secrets unrecoverable.
GD_AUTH_SECRET_KEY=change-me-in-production

# ── Token expiry (optional) ───────────────────────────────────────────────────
# GD_TOKEN_EXPIRE_MIN=60
# GD_REFRESH_EXPIRE_DAYS=7

# ── Metadata APIs (optional - all configurable via Setup Wizard / Settings) ───
# Stored encrypted in the database. These env vars are passed to the container
# and can be used for initial configuration reference.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
STEAMGRIDDB_API_KEY=
RAWG_API_KEY=
SCREENSCRAPER_USERNAME=
SCREENSCRAPER_PASSWORD=
RA_API_KEY=
