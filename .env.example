# GamesDownloaderV3 — environment variables
# Copy to .env and fill in your values

# ── Host paths (base directory for all persistent data) ───────────────────────
GD_BASE_DIR=/APPS/GamesDownloaderV3

# ── Port (host port → container 8080) ─────────────────────────────────────────
GD_PORT=8080

# ── User / Group ID (optional — run container as specific UID/GID) ────────────
# Leave empty to run as root (default in container)
PUID=
PGID=

# ── Debug mode ────────────────────────────────────────────────────────────────
GD_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=gamesdownloader
DB_USER=gd
DB_PASSWD=change-me
DB_ROOT_PASSWD=change-me-root

# ── Redis password ────────────────────────────────────────────────────────────
REDIS_PASSWORD=gd_redis_2026

# ── Auth — REQUIRED: generate with: openssl rand -hex 32 ─────────────────────
GD_AUTH_SECRET_KEY=change-me-in-production-use-long-random-string

# ── Token expiry (optional) ───────────────────────────────────────────────────
# GD_TOKEN_EXPIRE_MIN=60
# GD_REFRESH_EXPIRE_DAYS=7

# ── Metadata APIs (optional — all configurable via Setup Wizard / Settings) ───
# Stored encrypted in database. These env vars are passed to the container
# and can be used for initial configuration reference.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
STEAMGRIDDB_API_KEY=
RAWG_API_KEY=
SCREENSCRAPER_USERNAME=
SCREENSCRAPER_PASSWORD=
RA_API_KEY=
